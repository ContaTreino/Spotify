// ══════════════════════════════════════════
//  PLAYER
// ══════════════════════════════════════════
async function playIdx(i){
  if(i<0||i>=S.queue.length)return;
  S.idx=i;
  _errCount=0; _lastErrId=null; // reseta contador de erros para nova faixa
  const it=S.queue[i];
  const t=thumb(it);

  ['np-title','ps-title'].forEach(id=>$(id).textContent=it.title||'');
  ['np-art','ps-artist'].forEach(id=>$(id).textContent=it.uploader||'');
  const coverSrc=it.cover_xl||it.thumbnail||t;
  $('np-thumb').src=coverSrc;
  $('ps-art').src=coverSrc;
  $('ps-art').onerror=function(){this.src='';this.style.background='var(--s3)';this.onerror=null;};
  $('np-thumb').onerror=function(){this.src='';this.style.background='var(--s3)';this.onerror=null;};
  $('ps-like').classList.toggle('liked', S.liked.has(it.id));
  document.title=(it.title||'')+ ' – Deezer Music';
  npbar.classList.add('visible');
  updateHighlight();

  // Histórico
  S.history=S.history.filter(x=>x.id!==it.id);
  S.history.unshift(it);
  if(S.history.length>60)S.history.pop();
  localStorage.setItem('dzm_history', JSON.stringify(S.history));

  // Preview badge — esconde até loadedmetadata
  const prevBadge=$('ps-preview-badge');
  prevBadge.style.display='none';

  audio.src='/api/stream?id='+encodeURIComponent(it.id);

  try{
    await audio.play();
    setPlayIcons(true);
    _updateMediaSession(it);
    // Detecta preview (≤32s)
    audio.addEventListener('loadedmetadata', function onMeta(){
      audio.removeEventListener('loadedmetadata', onMeta);
      if(audio.duration && audio.duration<=32){
        prevBadge.style.display='block';
      }
    },{once:true});
  }catch(e){
    setPlayIcons(false);
    // AbortError é normal quando a faixa muda antes do play completar
    if(e.name !== 'AbortError') toast('Erro: '+e.message);
  }
}

function togglePlay(){
  if(!audio.src||audio.src===location.href)return;
  if(audio.paused) audio.play().then(()=>setPlayIcons(true));
  else { audio.pause(); setPlayIcons(false); }
}
function prevTrack(){
  if(audio.currentTime>3){audio.currentTime=0;return;}
  let n=S.idx-1; if(n<0)n=S.queue.length-1; playIdx(n);
}
function nextTrack(){
  if(S.shuffle){playIdx(Math.floor(Math.random()*S.queue.length));return;}
  let n=S.idx+1;
  if(n>=S.queue.length){if(S.repeat==='all')n=0;else return;}
  playIdx(n);
}
function setPlayIcons(pl){
  const ic=pl?'M6 19h4V5H6v14zm8-14v14h4V5h-4z':'M8 5v14l11-7z';
  [$('np-playicon'),$('np-playicon2'),$('ps-playicon')].forEach(el=>{
    if(!el)return;
    const p=el.querySelector('path')||el;
    if(p.tagName==='path')p.setAttribute('d',ic);
  });
}
function toggleShuffle(){
