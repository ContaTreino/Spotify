async function checkArlStatus(){
  try{
    const r = await fetch('/api/arl-status');
    const d = await r.json();
    if(!d.arl_valid){
      const banner = document.createElement('div');
      banner.id = 'arl-banner';
      banner.style.cssText = `
        position:sticky;top:0;left:0;right:0;z-index:199;
        background:#b91c1c;color:#fff;font-size:12px;font-weight:500;
        padding:9px 16px;display:flex;align-items:center;gap:10px;
        box-shadow:0 2px 12px rgba(0,0,0,.4);line-height:1.4;
      `;
      const msg = d.arl_configured
        ? '⚠️ ARL expirou — apenas preview 30s. Atualize a ARL no <code style="background:rgba(255,255,255,.2);padding:1px 5px;border-radius:3px">.env</code> e reinicie.'
        : '⚠️ ARL não configurada — apenas preview 30s. Adicione no <code style="background:rgba(255,255,255,.2);padding:1px 5px;border-radius:3px">.env</code>.';
      const close = document.createElement('button');
      close.innerHTML = '✕';
      close.style.cssText = 'margin-left:auto;background:none;border:none;color:#fff;font-size:16px;cursor:pointer;padding:0 4px;flex-shrink:0;line-height:1';
      close.onclick = () => banner.remove();
      banner.innerHTML = msg;
      banner.appendChild(close);
      // Insere no topo do main, não do body — aparece dentro do scroll
      const mainEl = $('mainEl');
      if(mainEl) mainEl.prepend(banner);
      else document.body.appendChild(banner);
    }
  } catch(e){ /* silencioso */ }
}

