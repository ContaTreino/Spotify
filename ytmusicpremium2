    toast('✓ Salvo na biblioteca');
  }else toast('Já está na biblioteca');
}
function downloadCurrent(){
  const it=S.queue[S.idx];if(!it)return;
  const btn=$('ps-dl-btn');
  if(btn) btn.classList.add('downloading');
  toast('⬇ Iniciando download…');
  const a=document.createElement('a');
  a.href=`/api/download?id=${encodeURIComponent(it.id)}&title=${encodeURIComponent(it.title||it.id)}`;
  a.download=it.title||it.id;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  setTimeout(()=>{if(btn)btn.classList.remove('downloading');},3000);
