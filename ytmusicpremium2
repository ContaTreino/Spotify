function shareTrack(){
  const it=S.queue[S.idx];if(!it)return;
  // song.link reconhece IDs do Deezer automaticamente
  const deezerUrl=`https://www.deezer.com/track/${it.id}`;
  const songLinkUrl=`https://song.link/d/${it.id}`;
  if(navigator.share){
    navigator.share({title:it.title, url:songLinkUrl}).catch(()=>{
      navigator.clipboard?.writeText(songLinkUrl).then(()=>toast('🔗 Link copiado!'));
    });
  } else {
    navigator.clipboard?.writeText(songLinkUrl).then(()=>toast('🔗 Link song.link copiado!'));
  }
}
function openSongLink(){
  const it=S.queue[S.idx];if(!it)return;
  window.open(`https://song.link/d/${it.id}`,'_blank','noopener');
}
function updateHighlight(){
  const curId = S.queue[S.idx]?.id;
  document.querySelectorAll('.ritem').forEach(el=>{
    // Tenta identificar por data-ri (resultados) ou por índice relativo dentro do pai
    const ri = el.dataset.ri;
    let isPlaying = false;
    if(ri !== undefined){
      // É um item de resultados — compara pelo id do item
      const item = (S._lastResultItems||[])[parseInt(ri)];
      isPlaying = item && item.id === curId;
    } else {
      // É um item de detalhe/artista — compara pelo id via S.queue
      const queueItem = S.queue.find(x=>x.id===curId);
      // Verifica se este ritem corresponde pela posição S.idx dentro do bloco pai
      const siblings = el.parentElement ? [...el.parentElement.querySelectorAll('.ritem')] : [];
      const localIdx = siblings.indexOf(el);
      isPlaying = localIdx === S.idx && !!queueItem;
    }
    el.classList.toggle('playing', isPlaying);
    el.querySelector('.rtitle')?.classList.toggle('pl', isPlaying);
  });
}

// ── Audio events ──
audio.addEventListener('timeupdate',()=>{
  if(!audio.duration)return;
  const p=(audio.currentTime/audio.duration)*100;
  $('np-prog').style.width=p+'%';
  $('seekFill').style.width=p+'%';
  $('seekThumb').style.left=p+'%';
  $('ps-cur').textContent=fmt(audio.currentTime);
});
audio.addEventListener('loadedmetadata',()=>{ $('ps-dur').textContent=fmt(audio.duration); });
audio.addEventListener('play',()=>setPlayIcons(true));
audio.addEventListener('pause',()=>setPlayIcons(false));
audio.addEventListener('ended',()=>{
  if(S.repeat==='one'){audio.currentTime=0;audio.play();return;}
  nextTrack();
});

// Pula automaticamente se a faixa falhar ao carregar
let _errCount = 0;
let _lastErrId = null;
audio.addEventListener('error', async ()=>{
  const it = S.queue[S.idx];
  if(!it) return;
  // Não conta o mesmo erro duas vezes (evento pode disparar múltiplas vezes)
  if(_lastErrId === it.id) return;
  _lastErrId = it.id;
  const label = it.title||'Faixa';
  let motivo = 'indisponível';
  try {
    const r = await fetch('/api/stream?id='+encodeURIComponent(it.id||''), {method:'HEAD'});
    if(r.status === 502) motivo = 'erro no servidor';
    else if(r.status === 404) motivo = 'não encontrada';
  } catch(e){}
  toast('⚠ "'+label+'" '+motivo+' — pulando...');
  _errCount++;
  if(_errCount >= Math.max(S.queue.length, 1)){
    _errCount=0; _lastErrId=null;
    toast('Nenhuma faixa disponível na fila.');
    return;
  }
  setTimeout(()=>nextTrack(), 1200);
});
audio.addEventListener('play', ()=>{ _errCount=0; _lastErrId=null; });

// ── Seek ──
function seekTo(e){
  if(!audio.duration)return;
  const r=$('seekTrack').getBoundingClientRect();
  const cx=e.touches?e.touches[0].clientX:e.clientX;
  audio.currentTime=Math.max(0,Math.min(1,(cx-r.left)/r.width))*audio.duration;
}
$('seekTrack').addEventListener('click',seekTo);
let _sk=false;
$('seekTrack').addEventListener('touchstart',e=>{_sk=true;e.preventDefault();seekTo(e);},{passive:false});
document.addEventListener('touchmove',e=>{if(_sk){e.preventDefault();seekTo(e);}},{passive:false});
document.addEventListener('touchend',()=>{_sk=false;});

