      <div class="chip active" data-section="home">Início</div>
      <div class="chip" data-q="hits brasil" data-type="track">Brasil</div>
      <div class="chip" data-q="pop hits" data-type="track">Pop</div>
      <div class="chip" data-q="funk brasil" data-type="track">Funk</div>
      <div class="chip" data-q="sertanejo" data-type="track">Sertanejo</div>
      <div class="chip" data-q="rap" data-type="track">Rap</div>
      <div class="chip" data-q="pagode" data-type="track">Pagode</div>
      <div class="chip" data-q="lofi chill" data-type="track">Lo-fi</div>
    </div>

    <!-- Em Alta (chart global) -->
    <div class="sec">
      <div class="sec-head"><span class="sec-title">🔥 Em alta</span></div>
      <div class="shelf" id="shelf-trending">
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
      </div>
    </div>

    <!-- Top Álbuns -->
    <div class="sec">
      <div class="sec-head"><span class="sec-title">💿 Álbuns em destaque</span></div>
      <div class="shelf" id="shelf-albums">
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
      </div>
    </div>

    <!-- Playlists Editoriais -->
    <div class="sec">
      <div class="sec-head"><span class="sec-title">🎧 Playlists</span></div>
      <div class="shelf" id="shelf-playlists">
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
      </div>
    </div>

    <!-- Artistas em destaque -->
    <div class="sec">
      <div class="sec-head"><span class="sec-title">🎤 Artistas</span></div>
      <div class="shelf" id="shelf-artists">
        <div class="shelf-card"><div class="skeleton sk-thumb" style="border-radius:50%"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb" style="border-radius:50%"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb" style="border-radius:50%"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
        <div class="shelf-card"><div class="skeleton sk-thumb" style="border-radius:50%"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>
      </div>
    </div>
  </div>

  <!-- SEARCH VIEW -->
  <div class="view" id="view-search">
    <div class="section-header">
      <button class="back-btn" onclick="navBack()" aria-label="Voltar">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l4.88-4.88c.39-.39.39-1.03 0-1.42-.39-.39-1.02-.39-1.41 0l-6.59 6.59c-.39.39-.39 1.02 0 1.41l6.59 6.59c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L7.83 13H19c.55 0 1-.45 1-1s-.45-1-1-1z"/></svg>
      </button>
      <span class="section-header-title" id="searchLabel">Resultados</span>
      <div style="width:40px"></div>
    </div>
    <!-- Filtros de tipo -->
    <div class="chips" id="searchTypeRow" style="padding-bottom:8px">
      <div class="chip active" data-stype="all">Tudo</div>
      <div class="chip" data-stype="track">Músicas</div>
      <div class="chip" data-stype="album">Álbuns</div>
      <div class="chip" data-stype="artist">Artistas</div>
      <div class="chip" data-stype="playlist">Playlists</div>
    </div>
    <div id="resultsList"></div>
  </div>

  <!-- DETAIL VIEW (album / playlist) -->
  <div class="view" id="view-detail">
    <div class="section-header">
      <button class="back-btn" onclick="navBack()" aria-label="Voltar">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l4.88-4.88c.39-.39.39-1.03 0-1.42-.39-.39-1.02-.39-1.41 0l-6.59 6.59c-.39.39-.39 1.02 0 1.41l6.59 6.59c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L7.83 13H19c.55 0 1-.45 1-1s-.45-1-1-1z"/></svg>
      </button>
      <span class="section-header-title" id="detail-header-title"></span>
      <div style="width:40px"></div>
    </div>
    <div class="detail-header">
      <img id="detail-cover" class="detail-cover" src="" alt=""/>
      <div class="detail-meta">
        <div class="detail-type" id="detail-type">ÁLBUM</div>
        <div class="detail-title" id="detail-title"></div>
        <div class="detail-sub" id="detail-sub"></div>
        <div style="font-size:12px;color:var(--dim);margin-top:4px" id="detail-count"></div>
        <div style="font-size:11px;color:var(--dim);margin-top:2px" id="detail-date"></div>
      </div>
    </div>
    <div class="detail-actions">
      <button class="btn-play-all" onclick="playDetailAll(false)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Reproduzir tudo
      </button>
      <button class="btn-shuffle-all" onclick="playDetailAll(true)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>
        Aleatório
      </button>
    </div>
    <div id="detail-tracks"></div>
  </div>

  <!-- ARTIST PROFILE VIEW -->
  <div class="view" id="view-artist">
    <div style="position:relative">
      <button class="back-btn" style="position:absolute;top:12px;left:12px;z-index:10;background:rgba(0,0,0,.5);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.12)" onclick="navBack()" aria-label="Voltar">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l4.88-4.88c.39-.39.39-1.03 0-1.42-.39-.39-1.02-.39-1.41 0l-6.59 6.59c-.39.39-.39 1.02 0 1.41l6.59 6.59c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L7.83 13H19c.55 0 1-.45 1-1s-.45-1-1-1z"/></svg>
      </button>
      <div id="artist-banner-wrap">
        <img id="artist-banner-img" class="artist-banner" src="" alt="" style="display:none"/>
        <div id="artist-banner-placeholder" class="artist-banner-placeholder">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="rgba(255,255,255,.15)"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
        </div>
      </div>
    </div>
    <div class="artist-header">
      <img id="artist-avatar" class="artist-avatar" src="" alt=""/>
      <div class="artist-info">
        <div class="artist-name" id="artist-name"></div>
        <div class="artist-fans" id="artist-fans"></div>
      </div>
    </div>
    <div style="padding:14px 16px 0;display:flex;gap:10px;flex-wrap:wrap">
      <button class="btn-play-all" style="flex:0 0 auto;padding:10px 22px" onclick="playArtistTop()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Reproduzir
      </button>
      <button class="btn-shuffle-all" style="padding:10px 18px" onclick="shuffleArtistTop()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>
        Aleatório
      </button>
    </div>
    <div id="artist-tracks"></div>
  </div>

  <!-- EXPLORE VIEW -->
  <div class="view" id="view-explore">
    <div class="sec-head" style="padding:20px 16px 8px"><span class="sec-title">Explorar géneros</span></div>
    <div class="explore-grid" id="exploreGrid"></div>
  </div>

  <!-- LIBRARY VIEW -->
  <div class="view" id="view-library">
    <div class="sec-head" style="padding:20px 16px 8px"><span class="sec-title">Biblioteca</span></div>
    <div class="lib-section">
      <div class="lib-title">♥ Curtidas</div>
      <div id="lib-liked"></div>
    </div>
    <div class="lib-section">
      <div class="lib-title">⏱ Histórico</div>
      <div id="lib-history"></div>
    </div>
  </div>

</main>

<!-- ── NOW PLAYING BAR ── -->
<div class="npbar" id="npbar" onclick="openPlayer()">
  <img class="np-thumb" id="np-thumb" src="" alt=""/>
  <div class="np-info">
    <div class="np-title" id="np-title">—</div>
    <div class="np-art" id="np-art">—</div>
  </div>
  <div class="np-btns">
    <button onclick="event.stopPropagation();prevTrack()" aria-label="Anterior">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
    </button>
    <button class="play-btn" onclick="event.stopPropagation();togglePlay()" aria-label="Play/Pause">
      <svg id="np-playicon2" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <button onclick="event.stopPropagation();nextTrack()" aria-label="Próxima">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2z"/></svg>
    </button>
  </div>
  <div class="np-progress"><div class="np-progress-fill" id="np-prog"></div></div>
</div>

<!-- ── FULL PLAYER SHEET ── -->
<div class="player-sheet" id="playerSheet">
  <div class="ps-handle"></div>
  <div class="ps-header">
    <span id="ps-context">Tocando agora</span>
    <button onclick="closePlayer()">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19 11H7.83l4.88-4.88c.39-.39.39-1.03 0-1.42-.39-.39-1.02-.39-1.41 0l-6.59 6.59c-.39.39-.39 1.02 0 1.41l6.59 6.59c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L7.83 13H19c.55 0 1-.45 1-1s-.45-1-1-1z"/></svg>
    </button>
  </div>
  <img id="ps-art" class="ps-art" src="" alt=""/>
  <span class="ps-preview-badge" id="ps-preview-badge" style="display:none">▶ Preview 30s — configure ARL para qualidade completa</span>
  <div class="ps-meta">
    <div class="ps-texts">
      <div class="ps-title" id="ps-title">—</div>
      <div class="ps-artist" id="ps-artist">—</div>
