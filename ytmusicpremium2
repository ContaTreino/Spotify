async function doSearch(q, type='all'){
  q=q.trim(); if(!q){navTo('home');return;}
  const ctrl = _newAbort('search');
  S.lastSearchQ=q; S.lastSearchType=type;
  navTo('search', S.currentView === 'search' ? {} : {push: true});
  $('searchLabel').textContent='Resultados: '+q;
  $('resultsList').innerHTML='<div class="spinner"></div>';
  document.querySelectorAll('#searchTypeRow .chip').forEach(c=>{
    c.classList.toggle('active', c.dataset.stype===type);
  });
  try{
    const n=30;
    let results=[];
    if(type==='all'||type==='track'){
      const d=await dzFetch('/search/track',{q,limit:n,output:'json'});
      (d.data||[]).forEach(t=>results.push(normTrack(t)));
    }
    if(type==='all'||type==='album'){
      const lim=type==='album'?n:Math.min(Math.floor(n/3),8);
      const d=await dzFetch('/search/album',{q,limit:lim,output:'json'});
      (d.data||[]).forEach(a=>results.push(normAlbum(a)));
    }
    if(type==='all'||type==='artist'){
      const lim=type==='artist'?n:Math.min(Math.floor(n/4),6);
      const d=await dzFetch('/search/artist',{q,limit:lim,output:'json'});
      (d.data||[]).forEach(a=>results.push(normArtist(a)));
    }
    if(type==='all'||type==='playlist'){
      const lim=type==='playlist'?n:Math.min(Math.floor(n/4),6);
      const d=await dzFetch('/search/playlist',{q,limit:lim,output:'json'});
      (d.data||[]).forEach(p=>results.push(normPlaylist(p)));
    }
    if(ctrl.signal.aborted) return;
    renderResults(results, q);
  }catch(e){
    if(e.name==='AbortError') return;
    $('resultsList').innerHTML=`<div class="empty"><p>Erro: ${esc(e.message)}</p></div>`;
  }
}

function renderResults(items, q){
  if(!items?.length){
    $('resultsList').innerHTML=`<div class="empty">
      <svg viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
      <p>Sem resultados para "${esc(q)}"</p>
    </div>`;
    return;
  }
  // Tracks para a fila (apenas músicas)
  S.queue=items.filter(x=>x._type==='track');
  // Guarda referência para delegation
  S._lastResultItems = items;

  $('resultsList').innerHTML='<div class="results" id="resultsInner">'+items.map((it,i)=>{
    const tp=getType(it);
    const isArt=it._type==='artist';
    const isTrack=it._type==='track';
    return `<div class="ritem" id="ri${i}" data-ri="${i}">
      <img class="rthumb ${isArt?'circle':''}" src="${esc(thumb(it))}" loading="lazy" onerror="this.style.opacity='0'"/>
      <div class="rinfo">
        <div class="rtitle">${typeBadge(it)}${esc(it.title||it.name||'')}</div>
        <div class="rmeta">${esc(it.uploader||it.name||'')}${it.duration?' · '+fmt(it.duration):''}${isTrack&&it.preview?'<span class="preview-badge">preview</span>':''}</div>
      </div>
      <button class="rmenu" data-rmenu="${i}" onclick="event.stopPropagation();openCtxFromIndex(${i})">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
      </button>
    </div>`;
  }).join('')+'</div>';

  // Event delegation — funciona para buscas múltiplas pois não usa once:true
  const inner = $('resultsInner');
  if(inner){
    inner.addEventListener('click', e=>{
      const ritem=e.target.closest('.ritem');
