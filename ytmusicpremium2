    <button onclick="openSongLink()" title="Ouvir em outras plataformas via song.link">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
      song.link
    </button>
  </div>
</div>

<!-- ── QUEUE SHEET ── -->
<div class="queue-sheet" id="queueSheet">
  <div class="qs-header">
    <span>Fila de reprodução</span>
    <button onclick="closeQueue()">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
  </div>
  <div class="qs-list" id="queueList"></div>
</div>

<!-- ── CONTEXT MENU ── -->
<div class="ctx-overlay" id="ctxOverlay" onclick="closeCtx()">
  <div class="ctx-menu" onclick="event.stopPropagation()">
    <div class="ctx-track-info">
      <img id="ctx-img" src="" alt=""/>
      <div>
        <div class="ctx-title" id="ctx-title"></div>
        <div class="ctx-artist" id="ctx-artist"></div>
      </div>
    </div>
    <div class="ctx-item" onclick="ctxAction('play')"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>Reproduzir</div>
    <div class="ctx-item" onclick="ctxAction('next')"><svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2z"/></svg>Tocar a seguir</div>
