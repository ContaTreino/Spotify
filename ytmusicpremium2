<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<meta name="theme-color" content="#0a0a0a"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<title>Deezer Music</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@300;400;500;600;700;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#0a0a0a;--s1:#111;--s2:#1a1a1a;--s3:#242424;--s4:#2e2e2e;
  --border:rgba(255,255,255,.08);
  --acc:#a238ff;--acc2:#6e14d9;--acc-rgb:162,56,255;
  --text:#f1f1f1;--muted:#aaa;--dim:#666;
  --radius:10px;--player:72px;--nav:60px;
  --ease:.2s cubic-bezier(.4,0,.2,1);
  --font:'Google Sans','Segoe UI',sans-serif;
}
html{background:var(--bg);color:var(--text);font-family:var(--font);-webkit-text-size-adjust:100%}
body{min-height:100dvh;overflow-x:hidden}
img{display:block;max-width:100%}
img[src=""]{visibility:hidden}
.ps-art[src=""]{visibility:visible;background:var(--s2)}
.np-thumb[src=""]{visibility:visible;background:var(--s3)}
button{font-family:var(--font);cursor:pointer;background:none;border:none;color:inherit}
input{font-family:var(--font)}
::-webkit-scrollbar{display:none}
#app{display:flex;flex-direction:column;min-height:100dvh}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:200;height:56px;padding:0 12px;display:flex;align-items:center;gap:10px;background:rgba(10,10,10,.94);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.logo{display:flex;align-items:center;gap:7px;flex-shrink:0;text-decoration:none;cursor:pointer}
.logo-icon{width:32px;height:32px;border-radius:7px;background:var(--acc);display:flex;align-items:center;justify-content:center}
.logo-icon svg{width:18px;height:18px;fill:#fff;margin-left:2px}
.logo-text{font-size:16px;font-weight:800;letter-spacing:-.3px;color:#fff;line-height:1}
.logo-text span{color:var(--acc)}
.search-bar{flex:1;display:flex;align-items:center;background:var(--s2);border:1px solid var(--border);border-radius:24px;height:38px;padding:0 4px 0 14px;gap:4px;transition:border var(--ease),background var(--ease)}
.search-bar:focus-within{border-color:rgba(162,56,255,.4);background:var(--s3)}
.search-bar input{flex:1;background:none;border:none;outline:none;color:var(--text);font-size:14px;min-width:0}
.search-bar input::placeholder{color:var(--dim)}
.search-bar button{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);flex-shrink:0;transition:color var(--ease),background var(--ease)}
.search-bar button:active{color:var(--text);background:var(--s4)}

/* ── BOTTOM NAV ── */
.bottomnav{position:fixed;bottom:0;left:0;right:0;z-index:200;height:var(--nav);background:rgba(10,10,10,.96);backdrop-filter:blur(24px);border-top:1px solid var(--border);display:flex;align-items:stretch}
.bottomnav a{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;text-decoration:none;font-size:10px;font-weight:500;color:var(--dim);transition:color var(--ease);padding-bottom:env(safe-area-inset-bottom,0px);cursor:pointer}
.bottomnav a svg{width:22px;height:22px;fill:currentColor}
.bottomnav a.active{color:var(--text)}
.bottomnav a.active svg{fill:var(--acc)}

/* ── MAIN ── */
.main{flex:1;overflow-y:auto;padding-bottom:calc(var(--player) + var(--nav) + 8px)}

/* ── VIEWS ── */
.view{display:none}.view.active{display:block}

/* ── SECTION HEADER (nav bar with back) ── */
.section-header{display:flex;align-items:center;justify-content:space-between;padding:8px 8px 0;height:52px;gap:4px;position:sticky;top:0;z-index:10;background:rgba(10,10,10,.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
.section-header-title{flex:1;font-size:16px;font-weight:700;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0 4px}
.back-btn{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--text);flex-shrink:0;transition:background var(--ease)}
.back-btn:active{background:var(--s3)}

/* ── SECTION ── */
.sec{padding:20px 16px 10px}
.sec-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.sec-title{font-size:18px;font-weight:700;letter-spacing:-.2px}
.sec-more{font-size:13px;color:var(--acc);font-weight:600;cursor:pointer}

/* ── CHIPS ── */
.chips{display:flex;gap:8px;overflow-x:auto;padding:0 16px;scrollbar-width:none;margin-bottom:4px}
.chip{flex-shrink:0;padding:7px 16px;border-radius:20px;font-size:13px;font-weight:600;background:var(--s2);border:1px solid var(--border);color:var(--muted);cursor:pointer;transition:all var(--ease);white-space:nowrap}
.chip.active{background:var(--acc);border-color:var(--acc);color:#fff}

/* ── SHELF ── */
.shelf{display:flex;gap:12px;overflow-x:auto;padding:0 16px 4px;scrollbar-width:none;scroll-snap-type:x mandatory}
.shelf-card{flex-shrink:0;width:140px;cursor:pointer;scroll-snap-align:start;transition:transform var(--ease)}
.shelf-card:active{transform:scale(.96)}
.shelf-card .thumb{width:140px;height:140px;border-radius:var(--radius);object-fit:cover;background:var(--s3);margin-bottom:8px;position:relative;overflow:hidden}
.shelf-card .thumb img{width:100%;height:100%;object-fit:cover}
.shelf-card .thumb-circle{border-radius:50%}
.shelf-card .card-title{font-size:13px;font-weight:600;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.shelf-card .card-sub{font-size:11px;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.type-badge{position:absolute;bottom:6px;left:6px;background:rgba(0,0,0,.75);color:#fff;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;text-transform:uppercase;letter-spacing:.04em}

/* ── RESULTS LIST ── */
.results{padding:0 0 8px}
.ritem{display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;transition:background var(--ease)}
.ritem:active{background:var(--s2)}
.ritem.playing{background:rgba(162,56,255,.08)}
.ritem .rthumb{width:52px;height:52px;border-radius:6px;object-fit:cover;background:var(--s3);flex-shrink:0}
.ritem .rthumb.circle{border-radius:50%}
.ritem .rinfo{flex:1;min-width:0}
.ritem .rtitle{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ritem .rtitle.pl{color:var(--acc)}
.ritem .rmeta{font-size:12px;color:var(--muted);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ritem .rbadge{display:inline-block;font-size:10px;font-weight:700;padding:1px 6px;border-radius:4px;margin-right:5px;text-transform:uppercase;vertical-align:middle}
.badge-music{background:#1a3a1a;color:#4caf50}
.badge-album{background:#1a1a3a;color:#7986cb}
.badge-single{background:#3a1a3a;color:#ce93d8}
.badge-playlist{background:#3a2a1a;color:#ffb74d}
.badge-artist{background:#2a1a3a;color:#bf9fff}
.ritem .rmenu{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--dim);flex-shrink:0;transition:color var(--ease),background var(--ease)}
.ritem .rmenu:active{background:var(--s3);color:var(--text)}
.preview-badge{font-size:9px;color:var(--acc);font-weight:700;padding:1px 5px;border:1px solid var(--acc);border-radius:4px;margin-left:4px;vertical-align:middle;opacity:.8}

/* ── DETAIL VIEW ── */
.detail-header{padding:20px 16px 0;display:flex;gap:16px;align-items:flex-end}
.detail-cover{width:120px;height:120px;border-radius:var(--radius);object-fit:cover;background:var(--s3);flex-shrink:0;box-shadow:0 8px 32px rgba(0,0,0,.5)}
.detail-meta{flex:1;min-width:0}
.detail-type{font-size:11px;font-weight:700;color:var(--acc);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.detail-title{font-size:20px;font-weight:800;line-height:1.2;margin-bottom:4px}
.detail-sub{font-size:13px;color:var(--muted)}
.detail-actions{display:flex;gap:10px;padding:16px 16px 8px;flex-wrap:wrap}
.btn-play-all{flex:1;min-width:120px;display:flex;align-items:center;justify-content:center;gap:8px;padding:12px;background:var(--acc);border-radius:24px;font-size:14px;font-weight:700;color:#fff;transition:opacity var(--ease)}
.btn-play-all:active{opacity:.8}
.btn-shuffle-all{display:flex;align-items:center;justify-content:center;gap:8px;padding:12px 18px;background:var(--s3);border-radius:24px;font-size:14px;font-weight:600;color:var(--text);transition:background var(--ease)}
.btn-shuffle-all:active{background:var(--s4)}
.btn-dl-all{display:flex;align-items:center;justify-content:center;gap:6px;padding:10px 14px;background:var(--s3);border-radius:24px;font-size:13px;font-weight:600;color:var(--text);border:1px solid var(--border)}

/* ── ARTIST PROFILE ── */
.artist-banner{width:100%;height:160px;object-fit:cover;background:var(--s2);display:block}
.artist-banner-placeholder{width:100%;height:160px;background:linear-gradient(135deg,#1a0a2e,#2d1455,#6e14d9,#a238ff);display:flex;align-items:center;justify-content:center}
.artist-header{display:flex;align-items:flex-end;gap:16px;padding:0 16px;margin-top:-44px;position:relative;z-index:2}
.artist-avatar{width:88px;height:88px;border-radius:50%;object-fit:cover;background:var(--s3);border:3px solid var(--bg);box-shadow:0 4px 20px rgba(0,0,0,.6);flex-shrink:0}
.artist-info{flex:1;min-width:0;padding-bottom:4px}
.artist-name{font-size:22px;font-weight:900;letter-spacing:-.3px;line-height:1.1;margin-bottom:2px;text-shadow:0 2px 8px rgba(0,0,0,.8)}
.artist-fans{font-size:12px;color:var(--muted);margin-top:3px}
.artist-desc{font-size:13px;color:var(--muted);line-height:1.5;padding:14px 16px 0;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
.artist-desc.expanded{-webkit-line-clamp:unset}
.artist-desc-toggle{font-size:12px;color:var(--acc);padding:4px 16px 0;cursor:pointer;font-weight:600}
.artist-section-title{font-size:16px;font-weight:700;padding:20px 16px 10px}

/* ── LIBRARY ── */
.lib-section{padding:0 16px 24px}
.lib-title{font-size:16px;font-weight:700;padding:20px 0 12px;border-bottom:1px solid var(--border);margin-bottom:8px}
.lib-item{display:flex;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer}
.lib-item:active{opacity:.7}
.lib-thumb{width:52px;height:52px;border-radius:8px;object-fit:cover;background:var(--s3);flex-shrink:0;display:flex;align-items:center;justify-content:center}
.lib-thumb svg{width:24px;height:24px;fill:var(--dim)}
.lib-info{flex:1;min-width:0}
.lib-name{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lib-sub{font-size:12px;color:var(--muted);margin-top:2px}

/* ── EXPLORE GRID ── */
.explore-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;padding:16px}
.explore-card{border-radius:var(--radius);overflow:hidden;aspect-ratio:16/9;display:flex;align-items:flex-end;padding:10px;cursor:pointer;position:relative;transition:transform var(--ease)}
.explore-card:active{transform:scale(.97)}
.explore-card span{font-size:14px;font-weight:800;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.8);z-index:1;position:relative}

/* ── NOW PLAYING BAR ── */
.npbar{position:fixed;bottom:var(--nav);left:0;right:0;z-index:190;height:var(--player);background:var(--s1);border-top:1px solid var(--border);display:flex;align-items:center;padding:0 12px;cursor:pointer;transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1)}
.npbar.visible{transform:translateY(0)}
.npbar .np-thumb{width:46px;height:46px;border-radius:6px;object-fit:cover;background:var(--s3);flex-shrink:0;margin-right:12px}
.npbar .np-info{flex:1;min-width:0}
.npbar .np-title{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.npbar .np-art{font-size:12px;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.npbar .np-btns{display:flex;align-items:center;gap:2px}
.npbar .np-btns button{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:color var(--ease)}
.npbar .np-btns .play-btn{width:44px;height:44px;border-radius:50%;background:var(--text);transition:transform var(--ease)}
.npbar .np-btns .play-btn:active{transform:scale(.92)}
.npbar .np-btns .play-btn svg{fill:var(--bg);width:22px;height:22px}
.np-progress{position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--s3)}
.np-progress-fill{height:100%;background:var(--acc);width:0%;transition:width .15s linear}

/* ── FULL PLAYER SHEET ── */
.player-sheet{position:fixed;inset:0;z-index:300;background:var(--bg);display:flex;flex-direction:column;transform:translateY(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);overflow-y:auto;overflow-x:hidden}
.player-sheet.open{transform:translateY(0)}
.ps-handle{width:36px;height:4px;border-radius:2px;background:var(--s4);margin:12px auto 0;flex-shrink:0}
.ps-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 0}
.ps-header span{font-size:12px;font-weight:600;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
.ps-header button{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:color var(--ease),background var(--ease)}
.ps-header button:active{background:var(--s2);color:var(--text)}
.ps-art{width:min(72vw,300px);aspect-ratio:1;border-radius:14px;object-fit:cover;background:var(--s2);margin:20px auto 20px;box-shadow:0 24px 64px rgba(0,0,0,.6);flex-shrink:0}
.ps-meta{padding:0 24px;margin-bottom:20px;display:flex;align-items:center;gap:10px}
.ps-meta .ps-texts{flex:1;min-width:0}
.ps-title{font-size:21px;font-weight:800;letter-spacing:-.3px;line-height:1.2;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ps-artist{font-size:15px;color:var(--muted);margin-top:4px}
.ps-like{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);flex-shrink:0;transition:color var(--ease)}
.ps-like.liked{color:var(--acc)}
.ps-seek{padding:0 24px;margin-bottom:6px}
.seek-track{width:100%;height:4px;background:var(--s3);border-radius:2px;position:relative;cursor:pointer;touch-action:none}
.seek-fill{height:100%;background:var(--text);border-radius:2px;pointer-events:none;width:0%}
.seek-track:active .seek-fill{background:var(--acc)}
.seek-thumb{position:absolute;top:50%;right:0;width:14px;height:14px;border-radius:50%;background:var(--text);transform:translate(50%,-50%);pointer-events:none;opacity:0;transition:opacity var(--ease)}
.seek-track:active .seek-thumb{opacity:1}
.seek-times{display:flex;justify-content:space-between;margin-top:6px;padding:0 2px}
.seek-times span{font-size:12px;color:var(--dim)}
.ps-controls{display:flex;align-items:center;justify-content:space-between;padding:4px 16px 0}
.ps-controls .ic{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:color var(--ease),background var(--ease)}
.ps-controls .ic:active{background:var(--s2);color:var(--text)}
.ps-controls .ic.active{color:var(--text)}
.ps-controls .ic svg{width:26px;height:26px}
.ps-controls .big-play{width:64px;height:64px;border-radius:50%;background:var(--acc);display:flex;align-items:center;justify-content:center;transition:transform var(--ease)}
.ps-controls .big-play:active{transform:scale(.92)}
.ps-controls .big-play svg{fill:#fff;width:30px;height:30px;margin-left:3px}
.ps-extras{display:flex;align-items:center;justify-content:space-around;padding:16px 16px calc(16px + env(safe-area-inset-bottom,0px));border-top:1px solid var(--border);margin-top:auto}
.ps-extras button{display:flex;flex-direction:column;align-items:center;gap:5px;font-size:11px;color:var(--muted);transition:color var(--ease)}
.ps-extras button:active,.ps-extras button.on{color:var(--text)}
.ps-extras button svg{width:22px;height:22px}
.ps-extras button.downloading{color:var(--acc);animation:pulse .8s infinite alternate}
@keyframes pulse{from{opacity:.6}to{opacity:1}}
/* Preview badge no player */
.ps-preview-badge{font-size:10px;color:var(--acc);font-weight:700;padding:2px 8px;border:1px solid var(--acc);border-radius:10px;margin:0 auto;display:block;width:fit-content;opacity:.85;margin-top:-16px;margin-bottom:16px}

/* ── QUEUE ── */
.queue-sheet{position:fixed;inset:0;z-index:310;background:var(--bg);display:flex;flex-direction:column;transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1)}
.queue-sheet.open{transform:translateY(0)}
.qs-header{display:flex;align-items:center;justify-content:space-between;padding:20px 16px 12px;border-bottom:1px solid var(--border);flex-shrink:0}
.qs-header span{font-size:17px;font-weight:700}
.qs-header button{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--muted)}
.qs-header button:active{background:var(--s2);color:var(--text)}
.qs-list{flex:1;overflow-y:auto;padding-bottom:16px}
.qi{display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;transition:background var(--ease)}
.qi:active{background:var(--s2)}
.qi.active{background:rgba(162,56,255,.08)}
.qi-num{width:20px;font-size:12px;color:var(--dim);text-align:center;flex-shrink:0}
.qi-num.playing{color:var(--acc)}
.qi-thumb{width:42px;height:42px;border-radius:5px;object-fit:cover;background:var(--s3);flex-shrink:0}
.qi-info{flex:1;min-width:0}
.qi-title{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.qi-title.playing{color:var(--acc)}
.qi-sub{font-size:11px;color:var(--muted);margin-top:2px}

/* ── SKELETON / LOADING ── */
.skeleton{background:linear-gradient(90deg,var(--s2) 25%,var(--s3) 50%,var(--s2) 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;border-radius:6px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.sk-thumb{width:140px;height:140px;border-radius:var(--radius)}
.sk-line{height:12px;margin-top:8px}
.sk-line-sm{height:10px;width:70%;margin-top:5px}
.spinner{width:28px;height:28px;border:3px solid var(--s3);border-top-color:var(--acc);border-radius:50%;animation:spin .6s linear infinite;margin:40px auto}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── EMPTY ── */
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:260px;gap:12px;color:var(--dim);padding:24px}
.empty svg{width:52px;height:52px;opacity:.3;fill:var(--muted)}
.empty p{font-size:14px;text-align:center;line-height:1.5}

/* ── TOAST ── */
.toast{position:fixed;bottom:calc(var(--player) + var(--nav) + 12px);left:50%;transform:translateX(-50%) translateY(12px);background:var(--s4);color:var(--text);padding:10px 18px;border-radius:20px;font-size:13px;font-weight:500;opacity:0;pointer-events:none;transition:all .2s;z-index:500;white-space:nowrap;max-width:calc(100vw - 32px);overflow:hidden;text-overflow:ellipsis}
.toast.on{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── CONTEXT MENU ── */
.ctx-overlay{position:fixed;inset:0;z-index:400;background:rgba(0,0,0,.5);display:none}
.ctx-overlay.open{display:block}
.ctx-menu{position:fixed;bottom:0;left:0;right:0;z-index:401;background:var(--s2);border-radius:16px 16px 0 0;padding:8px 0 calc(8px + env(safe-area-inset-bottom,0px));transform:translateY(100%);transition:transform .25s cubic-bezier(.4,0,.2,1)}
.ctx-overlay.open .ctx-menu{transform:translateY(0)}
.ctx-track-info{display:flex;align-items:center;gap:12px;padding:12px 16px 10px;border-bottom:1px solid var(--border);margin-bottom:6px}
.ctx-track-info img{width:46px;height:46px;border-radius:6px;object-fit:cover;background:var(--s3)}
.ctx-track-info .ctx-title{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ctx-track-info .ctx-artist{font-size:12px;color:var(--muted)}
.ctx-item{display:flex;align-items:center;gap:14px;padding:13px 20px;cursor:pointer;font-size:14px;transition:background var(--ease)}
.ctx-item:active{background:var(--s3)}
.ctx-item svg{width:20px;height:20px;fill:var(--muted);flex-shrink:0}

/* ── DL btn in track row ── */
.ritem .dl-btn{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--dim);flex-shrink:0;transition:color var(--ease),background var(--ease)}
.ritem .dl-btn:active,.ritem .dl-btn.downloading{color:var(--acc);background:var(--s3)}

/* ── RELATED ARTISTS ── */
.related-artists{display:flex;gap:16px;padding:0 16px 4px;overflow-x:auto;scrollbar-width:none}
.rel-art{flex-shrink:0;width:80px;text-align:center;cursor:pointer}
.rel-art img{width:80px;height:80px;border-radius:50%;object-fit:cover;background:var(--s3);margin-bottom:6px;transition:transform var(--ease)}
.rel-art:active img{transform:scale(.93)}
.rel-art span{font-size:11px;font-weight:500;color:var(--muted);display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

@media(min-width:700px){
  :root{--player:90px}
  .topbar{padding:0 24px;height:60px}
  .search-bar{max-width:500px;margin:0 auto}
  .shelf-card{width:170px}.shelf-card .thumb{width:170px;height:170px}.sk-thumb{width:170px;height:170px}
  .ps-art{width:min(55vw,340px)}
  .main{padding-bottom:calc(var(--player) + var(--nav) + 16px)}
}
@media(min-width:1024px){
  .bottomnav{display:none}
  .npbar{bottom:0}
  .toast{bottom:calc(var(--player) + 12px)}
  .main{padding-bottom:calc(var(--player) + 16px)}
}
</style>
</head>
<body>
<div id="app">

<!-- ── TOP BAR ── -->
<header class="topbar">
  <div class="logo" onclick="navTo('home')">
    <div class="logo-icon">
      <svg viewBox="0 0 18 18"><path d="M3 3v12l12-6z"/></svg>
    </div>
    <span class="logo-text">Music<span>●</span></span>
  </div>
  <div class="search-bar">
    <input id="searchInput" type="search" placeholder="Músicas, álbuns, artistas..." autocomplete="off" enterkeyhint="search"/>
    <button id="searchBtn" aria-label="Buscar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
    </button>
  </div>
</header>

<!-- ── MAIN SCROLL ── -->
<main class="main" id="mainEl">

  <!-- HOME VIEW -->
  <div class="view active" id="view-home">
