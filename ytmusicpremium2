// ══════════════════════════════════════════
function openCtx(i, fromDetail){
  const items=fromDetail?S.detailItems:S.queue;
  const it=items[i]; if(!it)return;
  S.ctxItem=it; S.ctxIdx=i; S.ctxFromDetail=fromDetail;
  $('ctx-img').src=thumb(it);
  $('ctx-title').textContent=it.title||it.name||'';
  $('ctx-artist').textContent=it.uploader||'';
  $('ctxOverlay').classList.add('open');history.pushState({sheet:'ctx'},'',location.href);
}
function closeCtx(){$('ctxOverlay').classList.remove('open');}
function ctxAction(action){
  closeCtx(); const it=S.ctxItem; if(!it)return;
  if(action==='play'){
    if(S.ctxFromDetail) playDetail(S.ctxIdx,'dt');
    else playIdx(S.ctxIdx);
  }
  else if(action==='next'){S.queue.splice(S.idx+1,0,it);toast('⏭ Tocar a seguir');}
  else if(action==='queue'){S.queue.push(it);toast('+ Adicionado à fila');}
  else if(action==='like'){
    if(S.liked.has(it.id))S.liked.delete(it.id);
    else S.liked.add(it.id);
    localStorage.setItem('dzm_liked',JSON.stringify([...S.liked]));
    toast(S.liked.has(it.id)?'♥ Curtida':'♡ Removida');
  }
  else if(action==='save'){
    if(!S.library.find(x=>x.id===it.id)){
      S.library.unshift(it);
      localStorage.setItem('dzm_library',JSON.stringify(S.library));
      toast('✓ Salvo na biblioteca');
    }else toast('Já está na biblioteca');
  }
  else if(action==='download'){
    toast('⬇ Iniciando download…');
    const a=document.createElement('a');
    a.href=`/api/download?id=${encodeURIComponent(it.id)}&title=${encodeURIComponent(it.title||it.id)}`;
    a.download=it.title||it.id;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
  }
  else if(action==='share'){
    const deezerUrl=`https://www.deezer.com/track/${it.id}`;
    const songLinkUrl=`https://song.link/d/${it.id}`;
    if(navigator.share) navigator.share({title:it.title,url:songLinkUrl}).catch(()=>{
      navigator.clipboard?.writeText(songLinkUrl).then(()=>toast('🔗 Link copiado!'));
    });
    else navigator.clipboard?.writeText(songLinkUrl).then(()=>toast('🔗 song.link copiado!'));
  }
  else if(action==='songlink'){
    window.open(`https://song.link/d/${it.id}`,'_blank','noopener');
  }
}

