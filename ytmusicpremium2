    <div class="ctx-item" onclick="ctxAction('songlink')"><svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>Abrir no song.link</div>
  </div>
</div>

<!-- ── BOTTOM NAV ── -->
<nav class="bottomnav">
  <a id="nav-home" class="active" onclick="navTo('home')">
