        <div class="lib-info"><div class="lib-name">${esc(it.title||'')}</div><div class="lib-sub">${esc(it.uploader||'')}</div></div>
      </div>`).join('')
    : '<div style="color:var(--dim);font-size:13px;padding:8px 0">Nenhuma música tocada ainda</div>';
}
function playLibItem(i, src){
  const list=src==='liked'?S.history.filter(x=>S.liked.has(x.id)):S.history;
