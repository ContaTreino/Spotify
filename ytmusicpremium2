<script>
// ══════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════
const S = {
  queue:[], idx:-1, shuffle:false, repeat:'none',
  liked:    new Set(JSON.parse(localStorage.getItem('dzm_liked')||'[]')),
  history:  JSON.parse(localStorage.getItem('dzm_history')||'[]'),
  library:  JSON.parse(localStorage.getItem('dzm_library')||'[]'),
  ctxItem:null, ctxIdx:-1, ctxFromDetail:false,
  detailItems:[], artistTopTracks:[],
  currentView:'home', prevView:'home',
  lastSearchQ:'', lastSearchType:'all',
  _lastResultItems: [],
};

// ── ABORT CONTROLLER CENTRALIZADO ──────────────────────────────────────────
const _aborts = {};
function _newAbort(slot){
  if(_aborts[slot]) _aborts[slot].abort();
  const ctrl = new AbortController();
  _aborts[slot] = ctrl;
  return ctrl;
}
function _cancelAllContent(){ ['detail','artist','search'].forEach(s=>{ if(_aborts[s]){ _aborts[s].abort(); delete _aborts[s]; } }); }

const audio = document.getElementById('audioEl');
const npbar  = document.getElementById('npbar');
const sheet  = document.getElementById('playerSheet');
function $(id){return document.getElementById(id)}

// ── TOAST ──
let _tt;
function toast(msg, dur=2400){
  const el=$('toastEl'); el.textContent=msg; el.classList.add('on');
  clearTimeout(_tt); _tt=setTimeout(()=>el.classList.remove('on'), dur);
}

// ── UTILS ──
function fmt(s){
  if(!s||isNaN(s))return'0:00';
  return Math.floor(s/60)+':'+(~~(s%60)<10?'0':'')+~~(s%60);
}
function esc(s){const d=document.createElement('div');d.textContent=s||'';return d.innerHTML}
function fmtFans(n){
  if(!n)return'';
  if(n>=1e6) return (n/1e6).toFixed(1)+'M fãs';
  if(n>=1e3) return Math.round(n/1e3)+'K fãs';
  return n+' fãs';
}
function thumb(it){
  if(!it)return'';
  return it.cover_xl||it.thumbnail||'';
}
function isPreview(it){ return !it.preview_full; }

// ── TYPE HELPERS ──
function getType(it){
  const t=(it._type||'').toLowerCase();
  if(t==='artist')   return {label:'Artista',  cls:'badge-artist'};
  if(t==='album'){
    const rt=(it.record_type||'').toLowerCase();
    if(rt==='single'||rt==='ep') return {label:'Single', cls:'badge-single'};
    return {label:'Álbum', cls:'badge-album'};
  }
  if(t==='playlist') return {label:'Playlist', cls:'badge-playlist'};
  return {label:'Música', cls:'badge-music'};
}
function typeBadge(it){const t=getType(it);return`<span class="rbadge ${t.cls}">${t.label}</span>`}
function isExpandable(it){
  const t=(it._type||'').toLowerCase();
  return t==='album'||t==='playlist'||t==='artist';
}

// ══════════════════════════════════════════
//  NAVIGATION — pilha de views
// ══════════════════════════════════════════
// Cada entrada: { view, scrollTop }
const _navStack = [];

const _ROOT_VIEWS = new Set(['home','explore','library']);

function navTo(view, opts={}){
  const prev = S.currentView;

  // Salva posição de scroll da view atual na pilha
  if(_navStack.length > 0){
    _navStack[_navStack.length-1].scrollTop = $('mainEl').scrollTop;
  }

  // Se voltar para uma view que já está na pilha, desempilha até ela
  const existingIdx = _navStack.findIndex(e => e.view === view);
  if(!opts.push && existingIdx >= 0){
    _navStack.splice(existingIdx + 1);
  } else {
    _navStack.push({ view, scrollTop: 0 });
  }

  S.prevView = prev;
  S.currentView = view;

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  // Limpa todos os highlights do bottomnav
  document.querySelectorAll('.bottomnav a').forEach(a => a.classList.remove('active'));

  const el = $('view-' + view);
  if(el) el.classList.add('active');

  // Destaca no bottomnav: a view raiz mais próxima na pilha
  const rootInStack = [..._navStack].reverse().find(e => _ROOT_VIEWS.has(e.view));
  const navTarget = _ROOT_VIEWS.has(view) ? view : (rootInStack?.view || 'home');
  $('nav-' + navTarget)?.classList.add('active');

  const entry = _navStack[_navStack.length - 1];
  if(opts.restoreScroll && entry){
    requestAnimationFrame(() => { $('mainEl').scrollTop = entry.scrollTop || 0; });
  } else {
    $('mainEl').scrollTop = 0;
  }

  if(view === 'library') renderLibrary();
  if(view === 'explore') renderExplore();
  if(['home','explore','library'].includes(view)) _cancelAllContent();
}

function navBack(){
  // Fecha sheets abertas primeiro
  if(sheet.classList.contains('open')){ closePlayer(); return; }
  if($('queueSheet').classList.contains('open')){ closeQueue(); return; }
  if($('ctxOverlay').classList.contains('open')){ closeCtx(); return; }

  if(_navStack.length <= 1){
    if(S.currentView !== 'home') navTo('home');
    return;
  }

  _navStack.pop();
  const prev = _navStack[_navStack.length - 1];
  if(!prev){ navTo('home'); return; }

  S.currentView = prev.view;
  S.prevView = _navStack.length >= 2 ? _navStack[_navStack.length - 2].view : 'home';

  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.bottomnav a').forEach(a => a.classList.remove('active'));

  const el = $('view-' + prev.view);
  if(el) el.classList.add('active');

  // Destaca o nav correto
  const rootInStack = [..._navStack].reverse().find(e => _ROOT_VIEWS.has(e.view));
  const navTarget = _ROOT_VIEWS.has(prev.view) ? prev.view : (rootInStack?.view || 'home');
  $('nav-' + navTarget)?.classList.add('active');

  if(prev.view === 'library') renderLibrary();
  if(prev.view === 'explore') renderExplore();

  requestAnimationFrame(() => { $('mainEl').scrollTop = prev.scrollTop || 0; });
}

window.addEventListener('popstate', () => {
  history.pushState(null, '', location.href);
  navBack();
});
history.pushState(null, '', location.href);
// Inicializa a pilha com home
_navStack.push({ view: 'home', scrollTop: 0 });

// ══════════════════════════════════════════
//  HOME FEED — chart Deezer
// ══════════════════════════════════════════
const shelves={};
const skCard='<div class="shelf-card"><div class="skeleton sk-thumb"></div><div class="skeleton sk-line"></div><div class="skeleton sk-line-sm"></div></div>';

// ── API Deezer direta (sem passar pelo Flask) ──────────────────────────────
// Proxy Flask em /dz/ resolve CORS — api.deezer.com bloqueia chamadas diretas do browser
async function dzFetch(path, params={}){
  const url = new URL('/dz' + path, location.origin);
  Object.entries(params).forEach(([k,v])=>url.searchParams.set(k,v));
  const r = await fetch(url.toString());
  if(!r.ok) throw new Error('HTTP '+r.status);
  const d = await r.json();
  if(d.error) throw new Error(d.error?.message||'Deezer API error');
  return d;
}

function normTrack(t){
  const art=t.artist||{}; const alb=t.album||{};
  return{
    id:String(t.id||''), title:t.title||t.title_short||'Sem título',
    uploader:art.name||'', artist_id:String(art.id||''),
    album:alb.title||'', album_id:String(alb.id||''),
    duration:t.duration, preview:t.preview||'',
    thumbnail:alb.cover_medium||alb.cover||'',
    cover_xl:alb.cover_xl||alb.cover_big||'',
    _type:'track', rank:t.rank||0, explicit:t.explicit_lyrics||false,
    isrc:t.isrc||''
  };
}
function normAlbum(a){
  const art=a.artist||{};
  return{
    id:String(a.id||''), title:a.title||'Sem título',
    uploader:art.name||'', artist_id:String(art.id||''),
    thumbnail:a.cover_medium||a.cover||'',
    cover_xl:a.cover_xl||a.cover_big||'',
    nb_tracks:a.nb_tracks||0, release_date:a.release_date||'',
    record_type:a.record_type||'album', _type:'album'
  };
}
function normPlaylist(p){
  return{
    id:String(p.id||''), title:p.title||'Sem título',
    uploader:(p.creator||{}).name||(p.user||{}).name||'',
    thumbnail:p.picture_medium||p.picture||'',
    cover_xl:p.picture_xl||p.picture_big||'',
    nb_tracks:p.nb_tracks||0, _type:'playlist'
  };
}
function normArtist(a){
  return{
    id:String(a.id||''), name:a.name||'',
    thumbnail:a.picture_medium||a.picture||'',
    cover_xl:a.picture_xl||a.picture_big||'',
    nb_fans:a.nb_fan||a.nb_fans||0, _type:'artist'
  };
}

async function loadHomeFeed(){
  try{
    const d=await dzFetch('/chart/0');
    const tracks    = (d.tracks?.data||[]).slice(0,20).map(normTrack);
    const albums    = (d.albums?.data||[]).slice(0,12).map(normAlbum);
    const playlists = (d.playlists?.data||[]).slice(0,8).map(normPlaylist);
    const artists   = (d.artists?.data||[]).slice(0,10).map(normArtist);

    if(tracks.length){
      shelves['trending']=tracks;
      $('shelf-trending').innerHTML=buildShelf(tracks,'trending');
    }
    if(albums.length){
      shelves['albums']=albums;
      $('shelf-albums').innerHTML=buildShelf(albums,'albums');
    }
    if(playlists.length){
      shelves['playlists']=playlists;
      $('shelf-playlists').innerHTML=buildShelf(playlists,'playlists');
    }
    if(artists.length){
      shelves['artists']=artists;
      $('shelf-artists').innerHTML=buildArtistShelf(artists);
    }
  }catch(e){
    ['shelf-trending','shelf-albums','shelf-playlists','shelf-artists'].forEach(id=>{
      $(id).innerHTML='<span style="color:var(--dim);font-size:12px;padding:8px 16px">Erro ao carregar</span>';
    });
  }
}

function buildShelf(items, prefix){
  return items.map((it,i)=>{
    const t=getType(it);
    return `<div class="shelf-card" onclick="shelfCardClick('${prefix}',${i})">
      <div class="thumb">
        <img src="${esc(thumb(it))}" loading="lazy" onerror="this.style.display='none'"/>
        <span class="type-badge">${t.label}</span>
      </div>
      <div class="card-title">${esc(it.title||it.name||'')}</div>
      <div class="card-sub">${esc(it.uploader||it.name||'')}</div>
    </div>`;
  }).join('');
}

function buildArtistShelf(artists){
  return artists.map((a,i)=>`
    <div class="shelf-card" onclick="openArtistById('${esc(a.id)}','${esc(a.name||'')}','${esc(thumb(a))}')">
      <div class="thumb" style="border-radius:50%;overflow:hidden">
        <img src="${esc(thumb(a))}" loading="lazy" onerror="this.style.display='none'"/>
      </div>
      <div class="card-title" style="text-align:center">${esc(a.name||'')}</div>
      <div class="card-sub" style="text-align:center">Artista</div>
    </div>`).join('');
}

function shelfCardClick(prefix, i){
  const items=shelves[prefix]; if(!items)return;
  const it=items[i];
  if(it._type==='artist') openArtistById(it.id, it.name, thumb(it));
  else if(isExpandable(it)) openDetail(it);
  else { S.queue=[...items.filter(x=>x._type==='track')]; const qi=S.queue.findIndex(x=>x.id===it.id); playIdx(qi>=0?qi:0); }
}

// ══════════════════════════════════════════
//  DETAIL VIEW — álbum / playlist
// ══════════════════════════════════════════
async function openDetail(it){
  const ctrl = _newAbort('detail');
  navTo('detail', {push: true});
  const tp=getType(it);
  $('detail-cover').src=it.cover_xl||thumb(it)||'';
  $('detail-type').textContent=tp.label;
  $('detail-title').textContent=it.title||it.name||'';
  $('detail-sub').textContent=it.uploader||'';
  $('detail-count').textContent='';
  $('detail-date').textContent='';
  $('detail-tracks').innerHTML='<div class="spinner"></div>';
  S.detailItems=[];
  const _ht=$('detail-header-title');
  if(_ht) _ht.textContent=it.title||it.name||'';
  try{
    let info, rawTracks=[], coverXl='', thumb2='', title2='', sub2='', releaseDate='', recType='';
    if(it._type==='album'){
      [info] = await Promise.all([dzFetch(`/album/${it.id}`)]);
      const tdata = await dzFetch(`/album/${it.id}/tracks`, {limit:100});
      const art   = info.artist||{};
      coverXl     = info.cover_xl||info.cover_big||'';
      thumb2      = info.cover_medium||'';
      title2      = info.title||'';
      sub2        = art.name||'';
      releaseDate = info.release_date||'';
      recType     = info.record_type||'album';
      rawTracks   = (tdata.data||[]).map(t=>{
        const o=normTrack(t);
        if(!o.thumbnail) o.thumbnail=info.cover_medium||'';
        if(!o.cover_xl)  o.cover_xl=info.cover_xl||'';
        if(!o.album)     o.album=info.title||'';
        return o;
      });
    } else if(it._type==='playlist'){
      info = await dzFetch(`/playlist/${it.id}`);
      const tdata = await dzFetch(`/playlist/${it.id}/tracks`, {limit:200});
      const creator = info.creator||{};
      coverXl     = info.picture_xl||info.picture_big||'';
      thumb2      = info.picture_medium||'';
      title2      = info.title||'';
      sub2        = creator.name||'';
      rawTracks   = (tdata.data||[]).map(normTrack);
    } else { throw new Error('Tipo desconhecido'); }
    if(ctrl.signal.aborted) return;
    S.detailItems = rawTracks;
    $('detail-title').textContent=title2;
    $('detail-sub').textContent=sub2;
    $('detail-count').textContent=S.detailItems.length+' faixas';
    if(releaseDate) $('detail-date').textContent=releaseDate;
    if(coverXl||thumb2) $('detail-cover').src=coverXl||thumb2||'';
    if(recType){
      const lbl={album:'Álbum',single:'Single',ep:'EP'}[recType]||'Álbum';
      $('detail-type').textContent=lbl;
    }
    const _hdrTitle=$('detail-header-title');
    if(_hdrTitle) _hdrTitle.textContent=title2;
    $('detail-tracks').innerHTML='<div class="results">'+
      S.detailItems.map((tr,i)=>trackRow(tr,i,'dt')).join('')+'</div>';
  }catch(e){
    if(e.name==='AbortError') return;
    $('detail-tracks').innerHTML=`<div class="empty"><p>Erro: ${esc(e.message)}</p></div>`;
  }
}

async function openArtistById(id, name, avatarFallback){
  const ctrl = _newAbort('artist');
  navTo('artist', {push: true});
  $('artist-name').textContent=name||'';
  $('artist-fans').textContent='';
  $('artist-avatar').src=avatarFallback||'';
  $('artist-banner-img').style.display='none';
  $('artist-banner-placeholder').style.display='flex';
  $('artist-tracks').innerHTML='<div class="spinner"></div>';
  S.detailItems=[];
  S.artistTopTracks=[];

  try{
    const [info, topR, albR] = await Promise.all([
      dzFetch(`/artist/${id}`),
      dzFetch(`/artist/${id}/top`, {limit:20}),
      dzFetch(`/artist/${id}/albums`, {limit:30}),
    ]);
    let related = [];
    try{ const relR=await dzFetch(`/artist/${id}/related`,{limit:8}); related=(relR.data||[]).map(normArtist); }catch(e){}
    if(ctrl.signal.aborted) return;

    const top_tracks = (topR.data||[]).map(normTrack);
    const allAlbums  = (albR.data||[]).map(normAlbum);
    const singles    = allAlbums.filter(a=>['single','ep'].includes(a.record_type));
    const albums     = allAlbums.filter(a=>a.record_type==='album');
    const d = { ...normArtist(info), top_tracks, albums, singles, related,
                avatar:info.picture_medium||info.picture||'',
                banner:info.picture_xl||'', nb_fans:info.nb_fan||0 };

    $('artist-name').textContent=d.name||name;
    if(d.nb_fans) $('artist-fans').textContent=fmtFans(d.nb_fans);
    if(d.cover_xl||d.avatar){
      $('artist-avatar').src=d.avatar||d.cover_xl||'';
    }
    if(d.banner){
      $('artist-banner-img').src=d.banner;
      $('artist-banner-img').style.display='block';
      $('artist-banner-placeholder').style.display='none';
    }

    S.detailItems    = d.top_tracks||[];
    S.artistTopTracks= d.top_tracks||[];

    let html='';

    // ── Top Faixas ──
    if(d.top_tracks?.length){
      html+=`<div class="artist-section-title">🔥 Músicas populares</div>
        <div class="results">${d.top_tracks.slice(0,10).map((tr,i)=>trackRow(tr,i,'at')).join('')}</div>`;
    }

    // ── Álbuns ──
    if(d.albums?.length){
      const albumItems=d.albums;
      window._artistAlbums=albumItems;
      html+=`<div class="artist-section-title">💿 Álbuns</div>
        <div class="shelf" style="padding:0 16px 4px;gap:12px;overflow-x:auto;display:flex;scroll-snap-type:x mandatory">
        ${albumItems.map((al,i)=>`
          <div class="shelf-card" style="flex-shrink:0;width:130px;scroll-snap-align:start;cursor:pointer" onclick="openDetail(window._artistAlbums[${i}])">
            <div class="thumb" style="width:130px;height:130px;border-radius:10px;overflow:hidden;background:var(--s3);position:relative">
              <img src="${esc(al.cover_xl||al.thumbnail||'')}" style="width:100%;height:100%;object-fit:cover" loading="lazy"/>
              <span class="type-badge">Álbum</span>
            </div>
            <div class="card-title" style="font-size:12px;font-weight:600;margin-top:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(al.title)}</div>
            <div class="card-sub" style="font-size:11px;color:var(--dim)">${esc(al.release_date||'')}</div>
          </div>`).join('')}
        </div>`;
    }

    // ── Singles ──
    if(d.singles?.length){
      const singleItems=d.singles;
      window._artistSingles=singleItems;
      html+=`<div class="artist-section-title">🎵 Singles & EPs</div>
        <div class="shelf" style="padding:0 16px 4px;gap:12px;overflow-x:auto;display:flex;scroll-snap-type:x mandatory">
        ${singleItems.map((si,i)=>`
          <div class="shelf-card" style="flex-shrink:0;width:130px;scroll-snap-align:start;cursor:pointer" onclick="openDetail(window._artistSingles[${i}])">
            <div class="thumb" style="width:130px;height:130px;border-radius:10px;overflow:hidden;background:var(--s3);position:relative">
              <img src="${esc(si.cover_xl||si.thumbnail||'')}" style="width:100%;height:100%;object-fit:cover" loading="lazy"/>
              <span class="type-badge">Single</span>
            </div>
            <div class="card-title" style="font-size:12px;font-weight:600;margin-top:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(si.title)}</div>
            <div class="card-sub" style="font-size:11px;color:var(--dim)">${esc(si.release_date||'')}</div>
          </div>`).join('')}
        </div>`;
    }

    // ── Artistas relacionados ──
    if(d.related?.length){
      html+=`<div class="artist-section-title">🎤 Artistas similares</div>
        <div class="related-artists">
